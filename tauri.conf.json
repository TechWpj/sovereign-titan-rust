{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Titan",
  "version": "0.1.0",
  "identifier": "com.sovereign.titan",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sovereign Titan",
        "transparent": true,
        "decorations": true,
        "alwaysOnTop": false,
        "fullscreen": false,
        "maximized": true,
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null
    }
  }
}
